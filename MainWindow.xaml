<Window x:Class="SuneungMarker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="수특 영어를 휩쓸다 - 마킹 에디터" Height="900" Width="1300"
        WindowStartupLocation="CenterScreen" Background="#FAFAFA">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#C0645C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style x:Key="MarkBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
        <Style x:Key="UploadBtn" TargetType="Button">
            <Setter Property="Width" Value="350"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 상단 배너 -->
        <Border Grid.Row="0" Background="#C0645C">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <TextBlock Text="수특 영어를 휩쓸다" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="TxtVersion" Text="" FontSize="10" Foreground="#FFDDBBBB" VerticalAlignment="Center" Margin="8,4,0,0"/>
                    <TextBlock x:Name="TxtPageInfo" Text="" FontSize="14" Foreground="#FFDDDDDD" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="PnlNavButtons" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Visibility="Collapsed">
                    <Button Content="◀ 이전" Style="{StaticResource NavBtn}" Click="BtnPrev_Click" Background="#A0504A"/>
                    <Button Content="다음 ▶" Style="{StaticResource NavBtn}" Click="BtnNext_Click" Background="#A0504A"/>
                    <Button Content="🤖 현재분석" Style="{StaticResource NavBtn}" Click="BtnAiAnalyze_Click" Background="#9C27B0"/>
                    <Button Content="🤖 전체분석" Style="{StaticResource NavBtn}" Click="BtnAiAnalyzeAll_Click" Background="#7B1FA2"/>
                    <Button Content="💾 저장" Style="{StaticResource NavBtn}" Click="BtnSave_Click" Background="#2196F3"/>
                    <Button Content="📄 DOCX" Style="{StaticResource NavBtn}" Click="BtnExportDocx_Click" Background="#4CAF50"/>
                    <Button Content="📄 PDF" Style="{StaticResource NavBtn}" Click="BtnExportPdf_Click" Background="#E65100"/>
                    <Button Content="설정" Style="{StaticResource NavBtn}" Click="BtnSettings_Click" Background="#757575"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 마킹 도구바 -->
        <Border x:Name="PnlToolbar" Grid.Row="1" Background="#F0F0F0" Padding="10,5" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="마킹:" FontSize="13" FontWeight="Bold" Foreground="#666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="빈칸" Tag="빈칸" Style="{StaticResource MarkBtn}" Background="#FFC107" Click="BtnMark_Click"/>
                <Button Content="어휘" Tag="어휘" Style="{StaticResource MarkBtn}" Background="#FF9800" Click="BtnMark_Click"/>
                <Button Content="어법" Tag="어법" Style="{StaticResource MarkBtn}" Background="#D32F2F" Click="BtnMark_Click"/>
                <Button Content="연결어" Tag="연결어" Style="{StaticResource MarkBtn}" Background="#4CAF50" Click="BtnMark_Click"/>
                <Button Content="핵심" Tag="핵심" Style="{StaticResource MarkBtn}" Background="#795548" Click="BtnMark_Click"/>
                <Button Content="// 순서" Tag="순서" Style="{StaticResource MarkBtn}" Background="#2196F3" Click="BtnMark_Click"/>
                <Button Content="밑줄의미" Tag="밑줄의미" Style="{StaticResource MarkBtn}" Background="#00BCD4" Click="BtnMark_Click"/>
                <Button Content="서술형" Tag="서술형" Style="{StaticResource MarkBtn}" Background="#607D8B" Click="BtnMark_Click"/>
                <Button Content="제거" Tag="제거" Style="{StaticResource MarkBtn}" Background="#999" Click="BtnMark_Click"/>
                <TextBlock x:Name="TxtSelection" Text="  단어를 드래그 선택 → 마킹 버튼 클릭"
                           FontSize="11" Foreground="#AAA" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </Border>

        <!-- 시작 화면 (업로드) -->
        <Grid x:Name="PnlWelcome" Grid.Row="2" Grid.RowSpan="2">
            <Border Background="White" CornerRadius="8" Margin="100,50" Padding="40"
                    BorderBrush="#DDD" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📚" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="수능특강 영어 마킹 에디터" FontSize="24" FontWeight="Bold" Foreground="#C0645C" HorizontalAlignment="Center"/>
                    <TextBlock Text="1.hwp (지문) + 2.hwp (어휘) 파일을 불러와서 시작하세요" FontSize="13" Foreground="#999" HorizontalAlignment="Center" Margin="0,8,0,30"/>

                    <Button Content="📂  영어 지문 불러오기" Style="{StaticResource UploadBtn}" Background="#C0645C" Click="BtnLoad1_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock x:Name="TxtFile1" Text="선택 안 됨" FontSize="11" Foreground="#999"/>
                    </StackPanel>

                    <Button Content="📂  어휘 불러오기" Style="{StaticResource UploadBtn}" Background="#FF9800" Click="BtnLoad2_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <TextBlock x:Name="TxtFile2" Text="선택 안 됨" FontSize="11" Foreground="#999"/>
                    </StackPanel>

                    <Button x:Name="BtnStart" Content="▶  시작하기" Style="{StaticResource UploadBtn}" Background="#4CAF50" Click="BtnStart_Click" IsEnabled="False" Margin="0,20,0,0"/>
                    <Grid Width="350" Margin="0,8,0,0">
                        <ProgressBar x:Name="PrgLoad" Height="10" Visibility="Collapsed"
                                     Foreground="#4CAF50" Background="#E0E0E0"/>
                        <ProgressBar x:Name="PrgIndeterminate" Height="10" Visibility="Collapsed"
                                     IsIndeterminate="True" Foreground="#C0645C" Background="Transparent"/>
                    </Grid>
                    <TextBlock x:Name="TxtLoadStatus" Text="" FontSize="11" Foreground="#E8384F" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 에디터 (초기 숨김) -->
        <Grid x:Name="PnlEditor" Grid.Row="2" Margin="10" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="55*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="45*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <RichTextBox x:Name="RtbPassage" IsReadOnly="True" BorderThickness="0"
                                 FontSize="14" FontFamily="맑은 고딕" Background="Transparent"
                                 SelectionChanged="RtbPassage_SelectionChanged"/>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="Transparent" HorizontalAlignment="Stretch"/>

            <Border Grid.Column="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="해석 및 어휘 ✈" FontSize="14" FontWeight="Bold" Foreground="#C0645C" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtKorean" TextWrapping="Wrap" FontSize="12" Foreground="#333" LineHeight="22"/>
                        <Border Height="1" Background="#EEE" Margin="0,15"/>
                        <TextBlock x:Name="TxtVocab" TextWrapping="Wrap" FontSize="11" Foreground="#555" LineHeight="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 하단 -->
        <Border x:Name="PnlStatusBar" Grid.Row="3" Background="#F5F5F5" Padding="10,5" Visibility="Collapsed">
            <TextBlock x:Name="TxtStatus" Text="" FontSize="12" Foreground="#999" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <!-- AI 분석 오버레이 -->
        <Grid x:Name="PnlAiOverlay" Grid.Row="0" Grid.RowSpan="4" Visibility="Collapsed">
            <Border Background="#88000000"/>
            <Border Background="White" CornerRadius="12" Width="420" Height="220"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#DDD" BorderThickness="1" Padding="30">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🤖 AI 분석 중" FontSize="20" FontWeight="Bold" Foreground="#9C27B0" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtAiStatus" Text="준비 중..." FontSize="13" Foreground="#666" HorizontalAlignment="Center" Margin="0,12,0,8"/>
                    <ProgressBar x:Name="PrgAi" Height="10" Foreground="#9C27B0" Background="#E0E0E0" Margin="0,4"/>
                    <ProgressBar x:Name="PrgAiIndeterminate" Height="10" IsIndeterminate="True" Foreground="#CE93D8" Background="Transparent" Margin="0,2"/>
                    <TextBlock x:Name="TxtAiPercent" Text="0%" FontSize="14" FontWeight="Bold" Foreground="#9C27B0" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
